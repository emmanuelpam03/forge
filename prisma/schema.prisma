generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]

  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}


// PROJECTS

model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String?
  isPinned    Boolean  @default(false)

  chats       Chat[]
  documents Document[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([name])
}

// CHATS

model Chat {
  id             String   @id @default(cuid())

  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  title          String   @default("New Chat")
  summary        String?
  lastMessageAt  DateTime @default(now())

  isPinned       Boolean  @default(false)
  isArchived     Boolean  @default(false)

  messages       Message[]
  analytics      ChatRunAnalytics[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([projectId])
  @@index([lastMessageAt])
  @@index([createdAt])
  @@index([title])
}

// MESSAGES

model Message {
  id            String   @id @default(cuid())

  chatId         String
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  role           MessageRole
  content        String   @db.Text

  // AI Metadata (LangGraph / LangChain useful)

  modelUsed      String?
  provider       String?
  tokensInput    Int?
  tokensOutput   Int?
  latencyMs      Int?

  
  // LangSmith trace linking

  runId          String?
  traceId        String?

  createdAt      DateTime @default(now())

  @@index([chatId])
  @@index([createdAt])
  @@index([runId])
}

// USER PREFERENCES (single-user mode for now)

model Preference {
  id          String   @id @default(cuid())

  key         String   @unique
  value       String   @db.Text
  category    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
}

// MEMORY SUMMARY

model MemorySummary {
  id          String   @id @default(cuid())

  summary     String   @db.Text
  version     Int      @default(1)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ANALYTICS PER RUN / RESPONSE


model ChatRunAnalytics {
  id            String   @id @default(cuid())

  chatId         String
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)

  // request analytics

  modelUsed      String?
  provider       String?

  latencyMs      Int?
  tokensInput    Int?
  tokensOutput   Int?
  estimatedCost  Float?

  // LangSmith references

  runId          String?
  traceId        String?
  status         String?

  createdAt      DateTime @default(now())

  @@index([chatId])
  @@index([createdAt])
  @@index([runId])
}

// FUTURE DOCUMENTS / KNOWLEDGE BASE

model Document {
  id            String   @id @default(cuid())

  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  name          String
  mimeType      String?
  sizeBytes     Int?
  storageUrl    String?

  extractedText String?  @db.Text

  createdAt     DateTime @default(now())

  @@index([projectId])
  @@index([name])
}

// ENUMS

enum MessageRole {
  user
  assistant
  system
  tool
}